# Postgres (Neon in productie, Docker lokaal) — zonder deze variabele draait
# de app puur op live scrapers + mock-fallback
DATABASE_URL=postgres://postgres:test@localhost:54329/corebuild

# Amazon Associates (na goedkeuring) — voegt ?tag= toe aan Amazon-links
# AMAZON_ASSOCIATE_TAG=

# ── Auth: e-mail verzenden (Resend) ──
# E-mailverificatie bij registratie schakelt AUTOMATISCH aan zodra RESEND_API_KEY
# gezet is (zonder mailverzending kan niemand bevestigen). Zonder key blijven
# captcha + wegwerp-mailblokkade + social de spambescherming.
# RESEND_API_KEY=
# EMAIL_FROM=CoreBuild <noreply@corebuildnl.com>

# ── Better Auth basis ──
# Voorkomt de "Base URL could not be determined"-warning en is nodig voor
# correcte OAuth-redirects. Lokaal http://localhost:3000, in prod de live-URL.
# BETTER_AUTH_URL=http://localhost:3000
# BETTER_AUTH_SECRET=                 # lange willekeurige string (zet dit in productie)

# ── Social login (optioneel per provider) ──
# Vul de server-credentials in ÉN spiegel de actieve providers in
# NEXT_PUBLIC_SOCIAL_PROVIDERS, anders verschijnen de knoppen niet.
# Stel deze redirect/callback-URL in bij elke provider (vervang <provider>):
#   https://corebuildnl.com/api/auth/callback/<provider>
#   http://localhost:3000/api/auth/callback/<provider>     (voor lokaal testen)
# NEXT_PUBLIC_SOCIAL_PROVIDERS=google,microsoft,discord
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# ── CAPTCHA (Cloudflare Turnstile) ──
# Beschermt /sign-up/email en /sign-in/email tegen bots. Maak een site aan op
# dash.cloudflare.com → Turnstile. Site-key is publiek, secret blijft server-side.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
